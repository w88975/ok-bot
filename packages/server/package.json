{
  "name": "@ok-bot/server",
  "version": "0.1.0",
  "description": "ok-bot HTTP server — 基于 Hono 的 REST API",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json && node --watch dist/index.js",
    "dev:watch": "tsc --watch --preserveWatchOutput -p tsconfig.json",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@ok-bot/core": "workspace:*",
    "hono": "^4.7.2",
    "@hono/node-server": "^1.13.7"
  },
  "devDependencies": {
    "typescript": "^5.7.3",
    "@types/node": "^22.13.9"
  }
}
