{
  "_comment": "ok-bot server 配置示例。复制为 ok-bot.config.json 后修改",
  "port": 3000,
  "hostname": "0.0.0.0",
  "authToken": "your-secret-token-here",
  "managerOptions": {
    "requestTimeoutMs": 300000
  },
  "agents": [
    {
      "id": "personal-assistant",
      "workspace": "/Users/yourname/ok-bot-workspace",
      "provider": {
        "model": "openai-compat:GLM-4.7",
        "apiKey": "your-api-key",
        "baseURL": "https://api.z.ai/api/coding/paas/v4"
      },
      "maxIterations": 20,
      "temperature": 0.1,
      "maxTokens": 4096,
      "heartbeatIntervalSeconds": 1800
    },
    {
      "id": "code-assistant",
      "workspace": "/Users/yourname/code-workspace",
      "provider": {
        "model": "openai:gpt-4o",
        "apiKey": "sk-..."
      },
      "maxIterations": 40,
      "restrictToWorkspace": true
    }
  ]
}
